# Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_PYTHON_API_URL=http://localhost:8001
VITE_APP_NAME=TVU GDQP-AN Admin Portal

# Google Drive API Configuration
# Lấy từ Google Cloud Console
VITE_GOOGLE_API_KEY=your_api_key_here
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_client_secret_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Google Drive Folder ID (tùy chọn - để lấy file từ folder cụ thể)
# Nếu không set, sẽ lấy tất cả file PDF/Excel
VITE_GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Feature Flags
VITE_ENABLE_GOOGLE_DRIVE=true
VITE_ENABLE_EXCEL_EXPORT=true
VITE_ENABLE_OCR=true

# Debug Mode
VITE_DEBUG=false
+