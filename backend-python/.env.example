DATABASE_URL=postgresql://admin:password@localhost:5432/tvu_gdqp_admin

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://admin:password@localhost:27017
MONGODB_DB_NAME=tvu_documents

# ── Google Cloud Document AI ─────────────────────────────────────────────────
# Bước 1: Vào https://console.cloud.google.com → bật "Cloud Document AI API"
# Bước 2: Tạo processor loại "Form Parser" → copy Processor ID
# Bước 3: Tạo Service Account → tải JSON key
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us
DOCUMENTAI_PROCESSOR_ID=your-form-parser-processor-id
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account-key.json

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
S3_BUCKET_NAME=tvu-gdqp-admin-bucket
TESSERACT_PATH=/usr/bin/tesseract
OCR_LANGUAGE=vie
API_HOST=0.0.0.0
API_PORT=8000
